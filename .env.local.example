# Quran Foundation User API (optional)
# Bearer token for streaks, bookmarks, goals, and posts endpoints
# App works fully in the browser with localStorage; sync calls are skipped without this
QURAN_USER_TOKEN=your_quran_user_token_here

# Quran Foundation Client Credentials (Content API)
# Used if your access tier requires x-auth-token + x-client-id headers
# Leave blank for anonymous read access
QURAN_CLIENT_ID=
QURAN_AUTH_TOKEN=
