# Claude / Anthropic
# Required for server-side reflection generation via /app/api/claude/route.ts
# Never expose this to the browser
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Quran Foundation User API
# Bearer token for streaks, bookmarks, goals, and posts endpoints
# Required for server-side user API sync (app degrades to local-only without it)
QURAN_USER_TOKEN=your_quran_user_token_here

# Quran Foundation Client Credentials (Content API)
# Used if your access tier requires x-auth-token + x-client-id headers
# Leave blank for anonymous read access
QURAN_CLIENT_ID=
QURAN_AUTH_TOKEN=
